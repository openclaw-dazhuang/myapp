.container {
  padding: 40rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
  color: #333;
}

.input-area {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
  border: 2rpx solid #ddd;
  box-sizing: border-box;
}

.generate-btn {
  width: 100%;
  margin-top: 30rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  border-radius: 16rpx;
}

.generate-btn[loading] {
  opacity: 0.6;
}

.error {
  margin-top: 30rpx;
  padding: 20rpx;
  background: #fee;
  color: #f00;
  border-radius: 16rpx;
  font-size: 26rpx;
  text-align: center;
}

.result {
  margin-top: 40rpx;
}

.result-image {
  width: 100%;
  height: 600rpx;
  border-radius: 16rpx;
  background: #fff;
}

.save-btn {
  width: 100%;
  margin-top: 20rpx;
  background: #07c160;
  color: #fff;
  font-size: 28rpx;
  border-radius: 16rpx;
}